<p align="center" class="Style6"><U><font color="#0000AF">Le </font><span class="Style82">S</span><font color="#0000AF">yndicat </font><span class="Style82">I</span><font color="#0000AF">ntercommunal de </font><span class="Style82">R</span><font color="#0000AF">egroupement </font><span class="Style82">P</span><font color="#0000AF">&eacute;dagogique:</font></U></p>
<p align="center" class="Style83"><U><font color="#0000AF">Br&eacute;champs, Chaudon , Croisilles 
  , Ormoy , Saint-Laurent la Gatine :</font></U></p>
<table width="999" height="163" align="center">
  <tr>
    <td height="157" align="center"><img src="images/Panorama%202%20Ecole.jpg" alt="" width="1000" height="180" border="0" /></td>
